{
  "name": "Ollama Connector",
  "description": "Ollama local LLM connector for jjam-siem-dojo",
  "version": 1,
  "protocol": "http",
  "parameters": { "model": "PLACEHOLDER" },
  "credential": { "dummy_key": "dummy_value" },
  "actions": [
    {
      "action_type": "predict",
      "method": "POST",
      "url": "http://ollama:11434/v1/chat/completions",
      "headers": { "Content-Type": "application/json" },
      "request_body": "{ \"model\": \"${parameters.model}\", \"messages\": [{\"role\":\"user\",\"content\":\"${parameters.prompt}\"}] }"
    }
  ]
}
